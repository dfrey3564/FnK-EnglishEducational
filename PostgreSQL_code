-- 1. Clean the Slate
DROP VIEW IF EXISTS risk_action_summary;
DROP TABLE IF EXISTS action_plan;

-- 2. Create the Table (Strict Status Rule)
CREATE TABLE action_plan (
    id              SERIAL PRIMARY KEY,
    risk_id         INTEGER         REFERENCES fine_kinney_risk(id), 
    hierarchy       VARCHAR(50),    
    control_measure TEXT            NOT NULL,
    owner           VARCHAR(100),
    deadline        VARCHAR(20),    
    status          VARCHAR(30)     NOT NULL CHECK (status IN ('Open', 'In Progress', 'Closed')),
    created_at      TIMESTAMPTZ     DEFAULT NOW()
);

