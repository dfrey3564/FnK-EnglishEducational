-- 4. Recreate the View
CREATE VIEW risk_action_summary AS
SELECT
    fk.hazard,
    fk.score,
    fk.priority,
    ap.hierarchy,
    ap.control_measure,
    ap.owner,
    ap.deadline,
    ap.status
FROM fine_kinney_risk fk
LEFT JOIN action_plan ap
    ON fk.id = ap.risk_id;
